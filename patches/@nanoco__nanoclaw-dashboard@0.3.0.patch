+/**
+ * Agents page — NanoClaw fork addition (pnpm patch, not upstream).
+ * Per-channel recap of agent characteristics: provider/model, trigger,
+ * active MCP servers and derived access rights, plus the operational
+ * health checks. Data comes from the snapshot keys `agents_recap` and
+ * `health` pushed by the fork's dashboard pusher extensions.
+ */
+import { layout } from '../layout.js';
+export function agentsPage() {
+    return layout('Agents', '/dashboard/agents', `
+    <style>
+      #content button { background:var(--btn-bg); color:var(--link); border:1px solid var(--btn-border); border-radius:4px; padding:5px 8px; margin:1px; font-size:12px; cursor:pointer; }
+      #content button:hover { background:var(--btn-hover); }
+    </style>
+    <h2 class="page-title">Agents par channel</h2>
+    <div id="summary" class="cards"><div class="loading">Loading...</div></div>
+    <h3 class="section-title">Caractéristiques &amp; droits d'accès</h3>
+    <div id="content"><div class="loading">Loading...</div></div>
+    <h3 class="section-title">Santé opérationnelle</h3>
+    <div id="health"><div class="loading">Loading...</div></div>
+    <script>
+    (async () => {
+      try {
+        const data = await api('/api/agents-recap');
+        const rows = data.rows || [];
+        const health = data.health || [];
+
+        const providers = {};
+        for (const r of rows) providers[r.provider] = (providers[r.provider] || 0) + 1;
+        const bad = health.filter(h => h.status === 'warn' || h.status === 'error').length;
+        document.getElementById('summary').innerHTML = [
+          cardHtml('Channels', rows.length),
+          cardHtml('Providers', Object.entries(providers).map(([p, n]) => p + ' ×' + n).join(', ') || '-'),
+          cardHtml('Checks santé', health.length),
+          cardHtml('Anomalies', bad),
+        ].join('');
+
+        if (rows.length === 0) {
+          document.getElementById('content').innerHTML = '<div class="loading">No data yet</div>';
+        } else {
+          let html = '<table><tr><th>Channel</th><th>Agent group</th><th>Provider / Modèle</th>' +
+            '<th>Déclenchement</th><th>MCP actifs</th><th>Droits d\\'accès</th><th>Actions</th></tr>';
+          for (const r of rows) {
+            const provColor = r.provider === 'claude' ? 'blue' : r.provider === 'opencode' ? 'green' : r.provider === 'agy' ? 'purple' : 'gray';
+            const mcp = (r.mcp || []).map(m => badge(m, 'gray')).join(' ') || '<span style="color:#555">-</span>';
+            const rights = (r.rights || []).map(x => {
+              const warn = x.indexOf('⚠') >= 0;
+              const byInstr = x.indexOf('PAR INSTRUCTIONS') >= 0;
+              const strong = x.indexOf('GLOBAL') >= 0 || x.indexOf('Mount RW') >= 0;
+              const b = badge(x, warn ? 'red' : byInstr ? 'yellow' : strong ? 'yellow' : 'green');
+              return byInstr
+                ? '<span title="Règle suivie par le modèle (champ instructions du serveur MCP), PAS une barrière technique. Détail : ncl groups config get --id ' + esc(r.agentGroupId) + '">' + b + '</span>'
+                : b;
+            }).join(' ') || '<span style="color:#555">-</span>';
+            html += '<tr>' +
+              '<td style="font-weight:500">' + esc(r.channel) + '</td>' +
+              '<td style="color:#888">' + esc(r.folder) + '</td>' +
+              '<td>' + badge(r.provider, provColor) + ' <span style="font-size:12px">' + esc(r.model) + '</span>' +
+                (r.effort ? ' ' + badge('effort ' + r.effort, 'blue') : '') +
+                (r.thinking ? ' ' + badge('thinking ' + r.thinking, 'gray') : '') + '</td>' +
+              '<td style="font-size:12px;color:#888">' + esc(r.engage) + '</td>' +
+              '<td>' + mcp + '</td>' +
+              '<td>' + rights + '</td>' +
+              '<td style="white-space:nowrap">' + actionsCell(r) + '</td>' +
+              '</tr>';
+          }
+          html += '</table>';
+          html += '<div style="font-size:12px;color:#888;margin:-12px 0 24px">' +
+            badge('restreint PAR INSTRUCTIONS', 'yellow') +
+            ' = règle énoncée dans le champ <code>instructions</code> du serveur MCP et suivie par le modèle — ' +
+            'ce n\u2019est <b>pas</b> une barrière technique. Détail : <code>ncl groups config get --id &lt;agent-group-id&gt;</code> ' +
+            'ou le fragment <code>.claude-fragments/mcp-google-calendar.md</code> composé dans le prompt du groupe.</div>';
+          document.getElementById('content').innerHTML = html;
+        }
+
+        if (health.length === 0) {
+          document.getElementById('health').innerHTML = '<div class="loading">No health data</div>';
+        } else {
+          let hh = '<table><tr><th>Check</th><th>Statut</th><th>Détail</th></tr>';
+          for (const h of health) {
+            const color = h.status === 'ok' ? 'green' : h.status === 'warn' ? 'yellow' : h.status === 'error' ? 'red' : 'gray';
+            hh += '<tr><td style="font-weight:500">' + esc(h.name) + '</td>' +
+              '<td>' + badge(h.status, color) + '</td>' +
+              '<td style="font-size:12px">' + esc(h.detail) + '</td></tr>';
+          }
+          hh += '</table>';
+          document.getElementById('health').innerHTML = hh;
+        }
+      } catch (e) {
+        document.getElementById('content').innerHTML = '<div class="loading">Error: ' + esc(e.message) + '</div>';
+      }
+    })();
+
+    // --- Write actions (bounded: effort / model / thinking / live / restart) ---
+    const EFFORTS = ['', 'low', 'medium', 'high', 'xhigh', 'max'];
+    const THINKING = ['', 'adaptive', 'enabled', 'disabled', 'none'];
+    function sel(id, options, current, labelPrefix) {
+      return '<select id="' + id + '" style="margin:1px">' + options.map(o =>
+        '<option value="' + o + '"' + (o === (current || '') ? ' selected' : '') + '>' +
+        (o === '' ? labelPrefix + ': défaut' : o) + '</option>').join('') + '</select>';
+    }
+    function actionsCell(r) {
+      const k = encodeURIComponent(r.agentGroupId);
+      return sel('eff-' + k, EFFORTS, r.effort, 'effort') +
+        sel('thk-' + k, THINKING, r.thinking, 'thinking') +
+        '<input id="mdl-' + k + '" value="' + esc(r.model === '(défaut)' ? '' : r.model) + '" placeholder="modèle" style="width:110px;margin:1px;padding:5px">' +
+        '<button class="act" data-k="' + k + '" data-act="apply">Appliquer</button>' +
+        '<button class="act" data-k="' + k + '" data-act="restart-group">Restart</button>' +
+        '<button class="act" data-k="' + k + '" data-act="toggle-live">Live</button>' +
+        '<span id="st-' + k + '" style="font-size:11px;color:#888;margin-left:4px"></span>';
+    }
+    function writeToken(reset) {
+      if (reset) localStorage.removeItem('dashWriteToken');
+      let t = localStorage.getItem('dashWriteToken');
+      if (!t) {
+        t = prompt('Token ÉCRITURE du dashboard (DASHBOARD_WRITE_SECRET) :') || '';
+        if (t) localStorage.setItem('dashWriteToken', t);
+      }
+      return t;
+    }
+    async function postAction(body) {
+      const t = writeToken(false);
+      if (!t) return { ok: false, message: 'pas de token écriture' };
+      const res = await fetch('/api/actions', {
+        method: 'POST',
+        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + t },
+        body: JSON.stringify(body),
+      });
+      if (res.status === 401) { writeToken(true); return { ok: false, message: 'token écriture invalide (re-saisir)' }; }
+      return res.json();
+    }
+    document.addEventListener('click', async (ev) => {
+      const btn = ev.target.closest('button.act');
+      if (!btn) return;
+      const k = btn.dataset.k;
+      const gid = decodeURIComponent(k);
+      const st = document.getElementById('st-' + k);
+      st.textContent = '…';
+      st.style.color = 'var(--muted)';
+      if (btn.dataset.act === 'apply') {
+        const fields = [
+          ['effort', document.getElementById('eff-' + k).value],
+          ['thinking', document.getElementById('thk-' + k).value],
+          ['model', document.getElementById('mdl-' + k).value.trim()],
+        ];
+        const msgs = [];
+        for (const [field, value] of fields) {
+          const r = await postAction({ action: 'set-config', agentGroupId: gid, field, value });
+          if (!r.ok) { msgs.push(field + ': ✗ ' + r.message); break; }
+          msgs.push(field + ' ✓');
+        }
+        st.textContent = msgs.join(' · ') + ' — restart pour appliquer';
+        st.style.color = 'var(--warn)';
+      } else {
+        const r = await postAction({ action: btn.dataset.act, agentGroupId: gid });
+        st.textContent = (r.ok ? '✓ ' : '✗ ') + r.message;
+        st.style.color = r.ok ? 'var(--ok)' : 'var(--err)';
+      }
+    });
+
+    function cardHtml(label, value) {
+      return '<div class="card"><div class="label">' + esc(label) + '</div><div class="value" style="font-size:20px">' + esc(String(value)) + '</div></div>';
+    }
+    </script>
+  `);
+}
diff --git a/dist/ui/pages/jobs.js b/dist/ui/pages/jobs.js
new file mode 100644
index 0000000000000000000000000000000000000000..70bb43688808ba003d9d6c4820a42e5df13d079d
--- /dev/null
+++ b/dist/ui/pages/jobs.js
@@ -0,0 +1,199 @@
+/**
+ * Jobs page — NanoClaw fork addition (pnpm patch, not upstream).
+ * Scheduled tasks (cron/reminders) + running background jobs, with bounded
+ * write actions (add / update / pause / resume / cancel) guarded by the
+ * dedicated write token — same mechanism as the Agents page.
+ */
+import { layout } from '../layout.js';
+export function jobsPage() {
+    return layout('Jobs', '/dashboard/jobs', `
+    <style>
+      #addform input, #addform select, #addform textarea { margin:2px; }
+      #addform textarea { width: 100%; min-height: 54px; }
+      button.jact { background:var(--btn-bg); color:var(--link); border:1px solid var(--btn-border); border-radius:4px; padding:4px 8px; margin:1px; font-size:12px; cursor:pointer; }
+      button.jact:hover { background:var(--btn-hover); }
+      button.jact.danger { color:#f87171; border-color:#4a2a2a; background:#2a1a1a; }
+      [data-theme="light"] button.jact.danger { color:#b91c1c; border-color:#f3c1c1; background:#fde2e2; }
+      tr.jedit td { background:var(--hover); }
+      tr.jedit textarea { width:100%; min-height:110px; padding:8px; font-family:inherit; }
+      tr.jedit input { margin:2px; }
+    </style>
+    <h2 class="page-title">Jobs</h2>
+    <div id="summary" class="cards"><div class="loading">Loading...</div></div>
+    <h3 class="section-title">Jobs background en cours</h3>
+    <div id="bg"><div class="loading">Loading...</div></div>
+    <h3 class="section-title">Tâches planifiées (pending / paused)</h3>
+    <div class="detail-panel" id="addform">
+      <div style="font-size:13px;color:#ccc;margin-bottom:8px">Ajouter une tâche</div>
+      <select id="add-group"></select>
+      <input id="add-when" type="datetime-local" title="Première échéance (heure locale)">
+      <input id="add-cron" placeholder="cron 5 champs (vide = ponctuelle)" style="width:220px" title="ex: 0 18 * * 0">
+      <br>
+      <textarea id="add-prompt" placeholder="Prompt de la tâche…"></textarea>
+      <br>
+      <button class="jact" id="add-btn">Ajouter</button>
+      <span id="add-st" style="font-size:12px;color:#888;margin-left:8px"></span>
+    </div>
+    <div id="content"><div class="loading">Loading...</div></div>
+    <script>
+    let DATA = null;
+    let editIndex = -1;
+    async function load() {
+      DATA = await api('/api/jobs');
+      render();
+    }
+    function render() {
+      const jobs = DATA.scheduled || [];
+      const bg = DATA.bg || [];
+      const recurring = jobs.filter(j => j.recurrence);
+      document.getElementById('summary').innerHTML = [
+        cardHtml('Bg en cours', bg.length),
+        cardHtml('Récurrentes', recurring.length),
+        cardHtml('Ponctuelles', jobs.length - recurring.length),
+        cardHtml('En pause', jobs.filter(j => j.status === 'paused').length),
+      ].join('');
+
+      const groupSel = document.getElementById('add-group');
+      groupSel.innerHTML = (DATA.groups || []).map(g =>
+        '<option value="' + esc(g.id) + '">' + esc(g.name || g.id) + '</option>').join('');
+
+      if (bg.length === 0) {
+        document.getElementById('bg').innerHTML = '<div class="loading">Aucun job background en cours</div>';
+      } else {
+        let bh = '<table><tr><th>Groupe</th><th>Job</th><th>Depuis</th><th>Actions</th><th>Dernière action</th><th>Prompt</th></tr>';
+        for (const b of bg) {
+          bh += '<tr>' +
+            '<td>' + esc(b.groupName || b.agentGroupId) + '</td>' +
+            '<td>' + badge(b.jobId, 'blue') + '</td>' +
+            '<td>' + esc(Math.round((Date.now() - b.startedAt) / 1000) + 's') + '</td>' +
+            '<td>' + esc(String(b.actions)) + '</td>' +
+            '<td style="font-size:12px">' + esc(b.lastAction || '-') + '</td>' +
+            '<td style="font-size:12px;color:#888">' + esc(b.prompt || '') + '</td>' +
+            '</tr>';
+        }
+        document.getElementById('bg').innerHTML = bh + '</table>';
+      }
+
+      if (jobs.length === 0) {
+        document.getElementById('content').innerHTML = '<div class="loading">Aucune tâche planifiée</div>';
+        return;
+      }
+      let html = '<table><tr><th>Groupe</th><th>Prochaine échéance</th><th>Récurrence</th><th>Statut</th><th>Prompt</th><th>Actions</th></tr>';
+      for (let i = 0; i < jobs.length; i++) {
+        const j = jobs[i];
+        const overdue = j.processAfter && Date.parse(j.processAfter) < Date.now() - 120000;
+        html += '<tr>' +
+          '<td>' + esc(j.agentGroupName || j.agentGroupId) + '</td>' +
+          '<td>' + esc(j.processAfter ? new Date(j.processAfter).toLocaleString('fr-FR') : '-') +
+            (overdue ? ' ' + badge('en retard', 'red') : '') + '</td>' +
+          '<td>' + (j.recurrence ? badge(j.recurrence, 'purple') : '<span style="color:#555">ponctuelle</span>') + '</td>' +
+          '<td>' + badge(j.status, j.status === 'pending' ? 'green' : 'yellow') + '</td>' +
+          '<td style="font-size:12px;color:#aaa">' + esc(j.prompt) +
+            '<div style="font-size:10px;color:#555">' + esc(j.id) + '</div></td>' +
+          '<td style="white-space:nowrap">' +
+            '<button class="jact" data-i="' + i + '" data-act="edit">' + (editIndex === i ? 'Fermer' : 'Modifier') + '</button>' +
+            '<button class="jact" data-i="' + i + '" data-act="' + (j.status === 'paused' ? 'job-resume' : 'job-pause') + '">' +
+              (j.status === 'paused' ? 'Reprendre' : 'Pause') + '</button>' +
+            '<button class="jact danger" data-i="' + i + '" data-act="job-cancel">Supprimer</button>' +
+            '<div id="jst-' + i + '" style="font-size:11px;color:#888"></div>' +
+          '</td></tr>';
+        if (editIndex === i) {
+          html += '<tr class="jedit"><td colspan="6">' +
+            '<div style="font-size:12px;color:#888;margin-bottom:6px">Édition de ' + esc(j.id) + '</div>' +
+            '<textarea id="ed-prompt">' + esc(j.promptFull || j.prompt) + '</textarea><br>' +
+            'Échéance : <input id="ed-when" type="datetime-local" value="' + toLocalInput(j.processAfter) + '"> ' +
+            'Cron : <input id="ed-cron" value="' + esc(j.recurrence || '') + '" placeholder="vide = ponctuelle" style="width:180px"> ' +
+            '<button class="jact" data-i="' + i + '" data-act="save-edit">Enregistrer</button>' +
+            '<button class="jact" data-i="' + i + '" data-act="edit">Annuler</button>' +
+            '<span id="ed-st" style="font-size:11px;color:#888;margin-left:6px"></span>' +
+            '</td></tr>';
+        }
+      }
+      document.getElementById('content').innerHTML = html + '</table>';
+    }
+
+    function toLocalInput(iso) {
+      if (!iso) return '';
+      const d = new Date(iso);
+      const pad = n => String(n).padStart(2, '0');
+      return d.getFullYear() + '-' + pad(d.getMonth() + 1) + '-' + pad(d.getDate()) + 'T' + pad(d.getHours()) + ':' + pad(d.getMinutes());
+    }
+    function writeToken(reset) {
+      if (reset) localStorage.removeItem('dashWriteToken');
+      let t = localStorage.getItem('dashWriteToken');
+      if (!t) {
+        t = prompt('Token ÉCRITURE du dashboard (DASHBOARD_WRITE_SECRET) :') || '';
+        if (t) localStorage.setItem('dashWriteToken', t);
+      }
+      return t;
+    }
+    async function postAction(body) {
+      const t = writeToken(false);
+      if (!t) return { ok: false, message: 'pas de token écriture' };
+      const res = await fetch('/api/actions', {
+        method: 'POST',
+        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + t },
+        body: JSON.stringify(body),
+      });
+      if (res.status === 401) { writeToken(true); return { ok: false, message: 'token écriture invalide (re-saisir)' }; }
+      return res.json();
+    }
+
+    document.getElementById('add-btn').addEventListener('click', async () => {
+      const st = document.getElementById('add-st');
+      const whenLocal = document.getElementById('add-when').value;
+      st.textContent = '…';
+      const r = await postAction({
+        action: 'job-add',
+        agentGroupId: document.getElementById('add-group').value,
+        prompt: document.getElementById('add-prompt').value,
+        processAfter: whenLocal ? new Date(whenLocal).toISOString() : '',
+        recurrence: document.getElementById('add-cron').value.trim() || null,
+      });
+      st.textContent = (r.ok ? '✓ ' : '✗ ') + r.message;
+      st.style.color = r.ok ? 'var(--ok)' : 'var(--err)';
+      if (r.ok) { document.getElementById('add-prompt').value = ''; setTimeout(load, 800); }
+    });
+
+    document.addEventListener('click', async (ev) => {
+      const btn = ev.target.closest('button.jact');
+      if (!btn || btn.id === 'add-btn') return;
+      const j = (DATA.scheduled || [])[Number(btn.dataset.i)];
+      if (!j) return;
+      const st = document.getElementById('jst-' + btn.dataset.i);
+      const base = { agentGroupId: j.agentGroupId, sessionDir: j.sessionDir, taskId: j.id };
+      let body = null;
+      if (btn.dataset.act === 'edit') {
+        editIndex = editIndex === Number(btn.dataset.i) ? -1 : Number(btn.dataset.i);
+        render();
+        return;
+      } else if (btn.dataset.act === 'save-edit') {
+        const whenLocal = document.getElementById('ed-when').value;
+        body = {
+          action: 'job-update', ...base,
+          prompt: document.getElementById('ed-prompt').value,
+          recurrence: document.getElementById('ed-cron').value.trim() || null,
+        };
+        if (whenLocal) body.processAfter = new Date(whenLocal).toISOString();
+      } else if (btn.dataset.act === 'job-cancel') {
+        if (!confirm('Supprimer la tâche ' + j.id + ' ?')) return;
+        body = { action: 'job-cancel', ...base };
+      } else {
+        body = { action: btn.dataset.act, ...base };
+      }
+      st.textContent = '…';
+      const r = await postAction(body);
+      st.textContent = (r.ok ? '✓ ' : '✗ ') + r.message;
+      st.style.color = r.ok ? 'var(--ok)' : 'var(--err)';
+      if (r.ok) { editIndex = -1; setTimeout(load, 800); }
+    });
+
+    function cardHtml(label, value) {
+      return '<div class="card"><div class="label">' + esc(label) + '</div><div class="value">' + esc(String(value)) + '</div></div>';
+    }
+    load().catch(e => {
+      document.getElementById('content').innerHTML = '<div class="loading">Error: ' + esc(e.message) + '</div>';
+    });
+    </script>
+  `);
+}
