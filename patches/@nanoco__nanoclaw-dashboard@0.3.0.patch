+++ b/dist/ui/pages/agents.js
@@ -0,0 +1,166 @@
+/**
+ * Agents page — NanoClaw fork addition (pnpm patch, not upstream).
+ * Per-channel recap of agent characteristics: provider/model, trigger,
+ * active MCP servers and derived access rights, plus the operational
+ * health checks. Data comes from the snapshot keys `agents_recap` and
+ * `health` pushed by the fork's dashboard pusher extensions.
+ */
+import { layout } from '../layout.js';
+export function agentsPage() {
+    return layout('Agents', '/dashboard/agents', `
+    <style>
+      #content button { background:#1e2a35; color:#7eb8da; border:1px solid #2a3a4a; border-radius:4px; padding:5px 8px; margin:1px; font-size:12px; cursor:pointer; }
+      #content button:hover { background:#253545; }
+    </style>
+    <h2 class="page-title">Agents par channel</h2>
+    <div id="summary" class="cards"><div class="loading">Loading...</div></div>
+    <h3 class="section-title">Caractéristiques &amp; droits d'accès</h3>
+    <div id="content"><div class="loading">Loading...</div></div>
+    <h3 class="section-title">Santé opérationnelle</h3>
+    <div id="health"><div class="loading">Loading...</div></div>
+    <script>
+    (async () => {
+      try {
+        const data = await api('/api/agents-recap');
+        const rows = data.rows || [];
+        const health = data.health || [];
+
+        const providers = {};
+        for (const r of rows) providers[r.provider] = (providers[r.provider] || 0) + 1;
+        const bad = health.filter(h => h.status === 'warn' || h.status === 'error').length;
+        document.getElementById('summary').innerHTML = [
+          cardHtml('Channels', rows.length),
+          cardHtml('Providers', Object.entries(providers).map(([p, n]) => p + ' ×' + n).join(', ') || '-'),
+          cardHtml('Checks santé', health.length),
+          cardHtml('Anomalies', bad),
+        ].join('');
+
+        if (rows.length === 0) {
+          document.getElementById('content').innerHTML = '<div class="loading">No data yet</div>';
+        } else {
+          let html = '<table><tr><th>Channel</th><th>Agent group</th><th>Provider / Modèle</th>' +
+            '<th>Déclenchement</th><th>MCP actifs</th><th>Droits d\\'accès</th><th>Actions</th></tr>';
+          for (const r of rows) {
+            const provColor = r.provider === 'claude' ? 'blue' : r.provider === 'opencode' ? 'green' : r.provider === 'agy' ? 'purple' : 'gray';
+            const mcp = (r.mcp || []).map(m => badge(m, 'gray')).join(' ') || '<span style="color:#555">-</span>';
+            const rights = (r.rights || []).map(x => {
+              const warn = x.indexOf('⚠') >= 0;
+              const byInstr = x.indexOf('PAR INSTRUCTIONS') >= 0;
+              const strong = x.indexOf('GLOBAL') >= 0 || x.indexOf('Mount RW') >= 0;
+              const b = badge(x, warn ? 'red' : byInstr ? 'yellow' : strong ? 'yellow' : 'green');
+              return byInstr
+                ? '<span title="Règle suivie par le modèle (champ instructions du serveur MCP), PAS une barrière technique. Détail : ncl groups config get --id ' + esc(r.agentGroupId) + '">' + b + '</span>'
+                : b;
+            }).join(' ') || '<span style="color:#555">-</span>';
+            html += '<tr>' +
+              '<td style="font-weight:500">' + esc(r.channel) + '</td>' +
+              '<td style="color:#888">' + esc(r.folder) + '</td>' +
+              '<td>' + badge(r.provider, provColor) + ' <span style="font-size:12px">' + esc(r.model) + '</span>' +
+                (r.effort ? ' ' + badge('effort ' + r.effort, 'blue') : '') +
+                (r.thinking ? ' ' + badge('thinking ' + r.thinking, 'gray') : '') + '</td>' +
+              '<td style="font-size:12px;color:#888">' + esc(r.engage) + '</td>' +
+              '<td>' + mcp + '</td>' +
+              '<td>' + rights + '</td>' +
+              '<td style="white-space:nowrap">' + actionsCell(r) + '</td>' +
+              '</tr>';
+          }
+          html += '</table>';
+          html += '<div style="font-size:12px;color:#888;margin:-12px 0 24px">' +
+            badge('restreint PAR INSTRUCTIONS', 'yellow') +
+            ' = règle énoncée dans le champ <code>instructions</code> du serveur MCP et suivie par le modèle — ' +
+            'ce n\u2019est <b>pas</b> une barrière technique. Détail : <code>ncl groups config get --id &lt;agent-group-id&gt;</code> ' +
+            'ou le fragment <code>.claude-fragments/mcp-google-calendar.md</code> composé dans le prompt du groupe.</div>';
+          document.getElementById('content').innerHTML = html;
+        }
+
+        if (health.length === 0) {
+          document.getElementById('health').innerHTML = '<div class="loading">No health data</div>';
+        } else {
+          let hh = '<table><tr><th>Check</th><th>Statut</th><th>Détail</th></tr>';
+          for (const h of health) {
+            const color = h.status === 'ok' ? 'green' : h.status === 'warn' ? 'yellow' : h.status === 'error' ? 'red' : 'gray';
+            hh += '<tr><td style="font-weight:500">' + esc(h.name) + '</td>' +
+              '<td>' + badge(h.status, color) + '</td>' +
+              '<td style="font-size:12px">' + esc(h.detail) + '</td></tr>';
+          }
+          hh += '</table>';
+          document.getElementById('health').innerHTML = hh;
+        }
+      } catch (e) {
+        document.getElementById('content').innerHTML = '<div class="loading">Error: ' + esc(e.message) + '</div>';
+      }
+    })();
+
+    // --- Write actions (bounded: effort / model / thinking / live / restart) ---
+    const EFFORTS = ['', 'low', 'medium', 'high', 'xhigh', 'max'];
+    const THINKING = ['', 'adaptive', 'enabled', 'disabled', 'none'];
+    function sel(id, options, current, labelPrefix) {
+      return '<select id="' + id + '" style="margin:1px">' + options.map(o =>
+        '<option value="' + o + '"' + (o === (current || '') ? ' selected' : '') + '>' +
+        (o === '' ? labelPrefix + ': défaut' : o) + '</option>').join('') + '</select>';
+    }
+    function actionsCell(r) {
+      const k = encodeURIComponent(r.agentGroupId);
+      return sel('eff-' + k, EFFORTS, r.effort, 'effort') +
+        sel('thk-' + k, THINKING, r.thinking, 'thinking') +
+        '<input id="mdl-' + k + '" value="' + esc(r.model === '(défaut)' ? '' : r.model) + '" placeholder="modèle" style="width:110px;margin:1px;background:#1a1a1a;color:#e0e0e0;border:1px solid #2a2a2a;border-radius:4px;padding:5px">' +
+        '<button class="act" data-k="' + k + '" data-act="apply">Appliquer</button>' +
+        '<button class="act" data-k="' + k + '" data-act="restart-group">Restart</button>' +
+        '<button class="act" data-k="' + k + '" data-act="toggle-live">Live</button>' +
+        '<span id="st-' + k + '" style="font-size:11px;color:#888;margin-left:4px"></span>';
+    }
+    function writeToken(reset) {
+      if (reset) localStorage.removeItem('dashWriteToken');
+      let t = localStorage.getItem('dashWriteToken');
+      if (!t) {
+        t = prompt('Token ÉCRITURE du dashboard (DASHBOARD_WRITE_SECRET) :') || '';
+        if (t) localStorage.setItem('dashWriteToken', t);
+      }
+      return t;
+    }
+    async function postAction(body) {
+      const t = writeToken(false);
+      if (!t) return { ok: false, message: 'pas de token écriture' };
+      const res = await fetch('/api/actions', {
+        method: 'POST',
+        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + t },
+        body: JSON.stringify(body),
+      });
+      if (res.status === 401) { writeToken(true); return { ok: false, message: 'token écriture invalide (re-saisir)' }; }
+      return res.json();
+    }
+    document.addEventListener('click', async (ev) => {
+      const btn = ev.target.closest('button.act');
+      if (!btn) return;
+      const k = btn.dataset.k;
+      const gid = decodeURIComponent(k);
+      const st = document.getElementById('st-' + k);
+      st.textContent = '…';
+      st.style.color = '#888';
+      if (btn.dataset.act === 'apply') {
+        const fields = [
+          ['effort', document.getElementById('eff-' + k).value],
+          ['thinking', document.getElementById('thk-' + k).value],
+          ['model', document.getElementById('mdl-' + k).value.trim()],
+        ];
+        const msgs = [];
+        for (const [field, value] of fields) {
+          const r = await postAction({ action: 'set-config', agentGroupId: gid, field, value });
+          if (!r.ok) { msgs.push(field + ': ✗ ' + r.message); break; }
+          msgs.push(field + ' ✓');
+        }
+        st.textContent = msgs.join(' · ') + ' — restart pour appliquer';
+        st.style.color = '#facc15';
+      } else {
+        const r = await postAction({ action: btn.dataset.act, agentGroupId: gid });
+        st.textContent = (r.ok ? '✓ ' : '✗ ') + r.message;
+        st.style.color = r.ok ? '#4ade80' : '#f87171';
+      }
+    });
+
+    function cardHtml(label, value) {
+      return '<div class="card"><div class="label">' + esc(label) + '</div><div class="value" style="font-size:20px">' + esc(String(value)) + '</div></div>';
+    }
+    </script>
+  `);
+}
